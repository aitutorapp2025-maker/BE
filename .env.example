# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=Vaha AI Backend
APP_ENV=development          # development | production
APP_PORT=8080

# ── PostgreSQL (GORM) ──────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vaha_ai
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Kolkata

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# ── Auth (JWT) ─────────────────────────────────────────────────────────────
JWT_SECRET=dev-insecure-change-me-in-production
JWT_TTL_HOURS=24

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to DISABLE sending (contact submissions are still saved).
# For Gmail: host smtp.gmail.com, port 587, user = your address, password = an
# App Password. For local testing use MailHog (host 127.0.0.1, port 1025, no auth).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=support@vahaai.com
SMTP_FROM_NAME=Vaha AI
